<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.commandgarden.daily-runner</string>

	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/node</string>
		<string>{{PROJECT_DIR}}/runner/daily-runner.js</string>
	</array>

	<key>WorkingDirectory</key>
	<string>{{PROJECT_DIR}}</string>

	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>9</integer>
		<key>Minute</key>
		<integer>0</integer>
	</dict>

	<key>StandardOutPath</key>
	<string>{{PROJECT_DIR}}/runner/daily-runner.stdout.log</string>

	<key>StandardErrorPath</key>
	<string>{{PROJECT_DIR}}/runner/daily-runner.stderr.log</string>

	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
	</dict>

	<key>RunAtLoad</key>
	<false/>
</dict>
</plist>
