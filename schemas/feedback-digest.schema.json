{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commandgarden.com/schemas/feedback-digest.v1.json",
  "title": "Feedback Digest",
  "description": "Aggregated feedback used as input to a daily pipeline run.",
  "type": "object",
  "required": ["schemaVersion", "runDate", "generatedAt", "summary", "suggestions", "bugs", "confusion"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "runDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "summary": {
      "type": "object",
      "required": ["totalItems", "byType"],
      "properties": {
        "totalItems": { "type": "integer", "minimum": 0 },
        "byType": {
          "type": "object",
          "properties": {
            "suggestion": { "type": "integer", "minimum": 0 },
            "bug": { "type": "integer", "minimum": 0 },
            "confusion": { "type": "integer", "minimum": 0 }
          },
          "required": ["suggestion", "bug", "confusion"]
        }
      }
    },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["content", "count"],
        "properties": {
          "content": { "type": "string" },
          "count": { "type": "integer", "minimum": 1 },
          "dayDate": { "type": ["string", "null"] }
        }
      }
    },
    "bugs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["content", "count"],
        "properties": {
          "content": { "type": "string" },
          "count": { "type": "integer", "minimum": 1 },
          "dayDate": { "type": ["string", "null"] }
        }
      }
    },
    "confusion": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["content", "count"],
        "properties": {
          "content": { "type": "string" },
          "count": { "type": "integer", "minimum": 1 },
          "dayDate": { "type": ["string", "null"] }
        }
      }
    },
    "recurringThemes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recentReactions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "integer" }
      }
    }
  }
}
