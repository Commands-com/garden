{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commandgarden.com/schemas/decision.v1.json",
  "title": "Decision",
  "description": "Daily pipeline decision record — candidates, scores, winner, and rationale.",
  "type": "object",
  "required": ["schemaVersion", "runDate", "generatedAt", "candidates", "winner", "rationale", "scoringDimensions"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "runDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "scoringDimensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "weight"],
        "properties": {
          "name": { "type": "string" },
          "weight": { "type": "number", "minimum": 0, "maximum": 100 },
          "description": { "type": "string" }
        }
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 3,
      "maxItems": 7,
      "items": {
        "type": "object",
        "required": ["id", "title", "summary", "scores", "totalScore", "rank"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "scores": {
            "type": "object",
            "properties": {
              "compoundingValue": { "type": "number", "minimum": 0, "maximum": 100 },
              "usefulness": { "type": "number", "minimum": 0, "maximum": 100 },
              "feasibility": { "type": "number", "minimum": 0, "maximum": 100 },
              "artifactClarity": { "type": "number", "minimum": 0, "maximum": 100 },
              "novelty": { "type": "number", "minimum": 0, "maximum": 100 },
              "feedbackPull": { "type": "number", "minimum": 0, "maximum": 100 },
              "shareability": { "type": "number", "minimum": 0, "maximum": 100 }
            },
            "required": ["compoundingValue", "usefulness", "feasibility", "artifactClarity", "novelty", "feedbackPull", "shareability"]
          },
          "totalScore": { "type": "number" },
          "rank": { "type": "integer", "minimum": 1 },
          "feedbackReferences": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "winner": {
      "type": "object",
      "required": ["candidateId", "title"],
      "properties": {
        "candidateId": { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "rationale": { "type": "string" },
    "featureType": {
      "type": "string",
      "description": "High-level category of the daily change (e.g. 'design', 'content', 'interaction', 'infrastructure', 'accessibility')."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Free-form tags for this day's change, used for archive filtering and era comparison."
    },
    "feedbackInfluence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "summary": { "type": "string" },
          "impact": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "description": "References to sibling artifact files in the same dated directory.",
      "properties": {
        "spec": { "type": "string", "description": "Filename of the spec artifact (e.g. spec.md)" },
        "buildSummary": { "type": "string", "description": "Filename of the build summary (e.g. build-summary.md)" },
        "review": { "type": "string", "description": "Filename of the review findings (e.g. review.md)" },
        "testResults": { "type": "string", "description": "Filename of the test results (e.g. test-results.json)" },
        "feedbackDigest": { "type": "string", "description": "Filename of the feedback digest (e.g. feedback-digest.json)" }
      }
    },
    "outreachSummary": {
      "type": "object",
      "description": "Summary of automated Bluesky outreach actions for transparency.",
      "properties": {
        "postUri": { "type": "string", "description": "AT URI of the daily Bluesky post" },
        "postsLiked": { "type": "integer", "minimum": 0 },
        "accountsFollowed": { "type": "integer", "minimum": 0 },
        "mentionsHandled": { "type": "integer", "minimum": 0 },
        "searchQueries": { "type": "array", "items": { "type": "string" } },
        "executedAt": { "type": "string", "format": "date-time" }
      }
    },
    "bluesky_post": {
      "type": "object",
      "description": "Pre-crafted Bluesky post content, written by the Review stage for automatic publishing.",
      "required": ["headline", "body"],
      "properties": {
        "headline": { "type": "string", "maxLength": 80, "description": "Attention-grabbing one-liner (max 80 chars)" },
        "body": { "type": "string", "maxLength": 250, "description": "2-3 sentence hook optimized for social engagement" },
        "alt_text": { "type": "string", "description": "Alt text for the attached screenshot, if any" }
      }
    },
    "bluesky_strategy": {
      "type": "object",
      "description": "Daily Bluesky audience growth strategy, written by the Review stage to guide automated outreach.",
      "properties": {
        "searchQueries": {
          "type": "array",
          "items": { "type": "string" },
          "description": "5-8 search terms to find relevant conversations on Bluesky"
        },
        "replyTemplates": {
          "type": "object",
          "description": "Pre-written replies for common question/comment types",
          "properties": {
            "whatIs": { "type": "string" },
            "howDoesItWork": { "type": "string" },
            "genericQuestion": { "type": "string" }
          }
        },
        "hashtagsToUse": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Hashtags to include in today's post"
        },
        "maxDailyActions": {
          "type": "integer",
          "minimum": 5,
          "maximum": 30,
          "description": "Maximum outreach actions (likes, follows, replies) for today"
        },
        "growthNotes": {
          "type": "string",
          "description": "Brief analysis of what's working/not working for audience growth based on recent metrics"
        }
      }
    }
  }
}
