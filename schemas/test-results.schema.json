{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commandgarden.com/schemas/test-results.v1.json",
  "title": "Test Results",
  "description": "UI/UX validation test results from the daily pipeline run.",
  "type": "object",
  "required": ["schemaVersion", "runDate", "generatedAt", "summary", "scenarios"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "runDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "summary": {
      "type": "object",
      "required": ["totalScenarios", "passed", "failed", "passRate"],
      "properties": {
        "totalScenarios": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "passRate": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "persona", "status"],
        "properties": {
          "name": { "type": "string" },
          "persona": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail", "skip"] },
          "description": { "type": "string" },
          "details": { "type": "string" },
          "duration": { "type": "string" }
        }
      }
    },
    "testPersonas": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
