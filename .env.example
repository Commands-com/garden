# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Stack name for CloudFormation
STACK_NAME=command-garden

# S3 bucket name (must be globally unique)
SITE_BUCKET_NAME=command-garden-site

# DynamoDB table prefix
DYNAMO_TABLE_PREFIX=command-garden

# Commands.com CLI path
COMMANDS_CLI_PATH=commands-com

# Site repo root (the Command Garden project being evolved)
SITE_REPO_PATH=/Users/dtannen/Code/commandgarden

# Controller profile ID for the pipeline
CONTROLLER_PROFILE_ID=default

# Saved room team IDs (or exact saved team names) for each stage
EXPLORE_TEAM_ID=
SPEC_TEAM_ID=
IMPLEMENTATION_TEAM_ID=
VALIDATION_TEAM_ID=
REVIEW_TEAM_ID=

# Daily runner settings
DAILY_RUN_HOUR=9
DAILY_RUN_MINUTE=0
MAX_TOKEN_BUDGET=500000
MAX_WALL_CLOCK_MINUTES=240
TIMEOUT_GRACE_MINUTES=15

# Alert webhook (optional - Slack, Discord, etc.)
ALERTS_WEBHOOK_URL=

# Game asset generation
GAME_ASSET_MANIFEST=site/game/assets-manifest.json
GAME_ASSET_OUTPUT_DIR=site/game/assets/generated
REPLICATE_API_TOKEN=
REPLICATE_API_BASE_URL=https://api.replicate.com/v1
REPLICATE_SPRITE_VERSION=
REPLICATE_ANIMATION_VERSION=
REPLICATE_TILE_VERSION=
REPLICATE_SPRITE_STYLE=topdown_asset
REPLICATE_TILE_STYLE=single_tile
REPLICATE_TILESET_STYLE=tileset
REPLICATE_TILE_WIDTH=32
REPLICATE_TILE_HEIGHT=32
REPLICATE_SPRITESHEET_STYLE=character_turnaround
REPLICATE_SPRITESHEET_FRAMES=4
REPLICATE_SPRITESHEET_COLUMNS=4
REPLICATE_SPRITESHEET_ROWS=1
REPLICATE_SPRITESHEET_ANIMATION=idle
REPLICATE_ANIMATION_STYLE=walking_and_idle
REPLICATE_ANIMATION_WIDTH=48
REPLICATE_ANIMATION_HEIGHT=48
REPLICATE_ANIMATION_RETURN_SPRITESHEET=true
REPLICATE_SPRITE_WIDTH=384
REPLICATE_SPRITE_HEIGHT=384
REPLICATE_REMOVE_BG=true
REPLICATE_BYPASS_PROMPT_EXPANSION=true
REPLICATE_NEGATIVE_PROMPT=realistic, photo, 3d, watermark, text, blurry, low contrast
MAX_REPLICATE_SPEND_PER_RUN=0.50
ESTIMATED_REPLICATE_SPRITE_COST=0.05
ESTIMATED_REPLICATE_ANIMATION_COST=0.08
ESTIMATED_REPLICATE_TILE_COST=0.06
ELEVENLABS_API_KEY=
ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_SFX_STYLE=stylized action-game sound effect, crisp transient, polished mix, organic-meets-synthetic texture, modern indie game audio, short and readable, no retro chiptune
ELEVENLABS_MUSIC_STYLE=modern indie action soundtrack, atmospheric electronic-organic texture, loopable, propulsive, polished browser-game mix, no retro chiptune

# AI game playtesting
OPENAI_API_KEY=
GAME_AI_PROVIDER=openai
GAME_AI_MODEL=gpt-5.4-mini
GAME_AI_REASONING_EFFORT=none
GAME_AI_API_KEY_ENV=OPENAI_API_KEY
GAME_AI_CODEX_BIN=codex
GAME_AI_CODEX_MODEL=gpt-5.4-mini
GAME_AI_CODEX_REASONING_EFFORT=low
GAME_AI_CODEX_PROFILE=
GAME_AI_CODEX_SANDBOX=read-only

# Bluesky (for daily feature announcements)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
